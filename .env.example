# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://charles:yourpassword@cluster0.xxxxx.mongodb.net/chequemart

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=a1b2c3d4e5f6...  (your generated string)
JWT_REFRESH_SECRET=z9y8x7w6v5u4...  (a different generated string)
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Paystack — from dashboard.paystack.com > Settings > API Keys
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxx

# Email — Gmail App Password (NOT your Gmail login password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourname@gmail.com
SMTP_PASS=abcd efgh ijkl mnop
EMAIL_FROM=Chequemart <noreply@chequemart.com>

# Frontend URL
CLIENT_URL=http://localhost:3000